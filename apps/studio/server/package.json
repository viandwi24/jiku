{
  "name": "@jiku-studio/server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:generate": "cd ../db && bun --env-file=../server/.env run db:generate",
    "db:migrate": "cd ../db && bun --env-file=../server/.env run db:migrate",
    "db:push": "cd ../db && bun --env-file=../server/.env run db:push",
    "db:studio": "cd ../db && bun --env-file=../server/.env run db:studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/openai": "^3.0.50",
    "@hono/node-server": "^1.14.3",
    "@jiku-studio/db": "workspace:*",
    "@jiku/core": "workspace:*",
    "@jiku/kit": "workspace:*",
    "@jiku/plugin-connector": "workspace:*",
    "@jiku/plugin-telegram": "workspace:*",
    "@jiku/types": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.146",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "hono": "^4.7.11",
    "jose": "^5.10.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1"
  }
}
