# ─── PostgreSQL ───────────────────────────────
POSTGRES_USER=jiku
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jiku

# ─── RustFS ───────────────────────────────────
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
S3_BUCKET=jiku

# ─── Qdrant (Vector DB for semantic memory) ──
# Leave empty to disable semantic search — it will gracefully fall back to keyword-only scoring.
QDRANT_URL=http://qdrant:6333

# ─── Timezone ─────────────────────────────────
TZ=Asia/Jakarta

# ─── App / Server ─────────────────────────────
SERVER_PORT=3001
JWT_SECRET=changeme-very-long-random-secret
JWT_EXPIRES_IN=7d
CREDENTIALS_ENCRYPTION_KEY=changeme-32-char-minimum-random-key
ANTHROPIC_API_KEY=
PUBLIC_URL=https://api.yourdomain.com
# Set to "true" to enable the browser control server (requires remote Chromium via CDP).
# Default false — leave disabled unless you have a browser container configured.
BROWSER_CONTROL_SERVER_ENABLED=false

# ─── Domains (for Traefik labels) ─────────────
API_DOMAIN=api.yourdomain.com         # HTTPS via Let's Encrypt
WEB_DOMAIN=app.yourdomain.com         # HTTPS via Let's Encrypt
RUSTFS_CONSOLE_DOMAIN=storage.yourdomain.com  # HTTP only
BROWSER_DOMAIN=browser.yourdomain.com         # noVNC viewer for the Chromium (CDP) container
CAMOFOX_DOMAIN=camofox.yourdomain.com         # CamoFox REST API (HTTPS via Let's Encrypt)

# ─── Browser stack (docker-compose.browser.yml) ───────────────────────────
# This section covers BOTH browser services:
#   • chrome   — Headless Chromium (CDP on :9222, noVNC viewer on :6080)
#   • camofox  — Firefox-based anti-fingerprint browser (REST API on :9377)
# Services in this compose file are optional — only spin up what you need.

# ── Chromium (chrome service) ─────────────────
# No extra env required. The service uses hardcoded SCREEN_* defaults (1920x1080x24),
# CDP_PORT=9222, NOVNC_PORT=6080. Studio app connects via ws://chrome:9222.

# ── CamoFox (camofox service) ─────────────────
# Image is built from packages/camofox/docker (clones jo-inc/camofox-browser at
# build time). Pin the upstream ref — use a commit SHA or tag for reproducible
# rebuilds; `master` tracks the latest upstream.
CAMOFOX_REF=master
# Bearer token for the Authorization header. REQUIRED to enable cookie import
# and generally recommended. Generate with `openssl rand -hex 32`.
CAMOFOX_API_KEY=changeme-generate-with-openssl-rand-hex-32
# Required to stop the CamoFox server via POST /stop.
CAMOFOX_ADMIN_KEY=changeme-separate-admin-key
# Session & tab limits. Tune based on host memory.
CAMOFOX_MAX_SESSIONS=20
CAMOFOX_MAX_TABS_PER_SESSION=10
# 30 min — session eviction
CAMOFOX_SESSION_TIMEOUT_MS=1800000
# 5 min — browser auto-shutdown when idle
CAMOFOX_IDLE_TIMEOUT_MS=300000
# Optional upstream proxy for all CamoFox traffic. Leave blank to disable.
CAMOFOX_PROXY_HOST=
CAMOFOX_PROXY_PORT=
CAMOFOX_PROXY_USERNAME=
CAMOFOX_PROXY_PASSWORD=

# ─── Next.js (baked at build time) ────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
