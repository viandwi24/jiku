POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db
POSTGRES_PORT=5432

PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/db
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
CREDENTIALS_ENCRYPTION_KEY=f8295e3c8ea3c9e54ce8dab88360ef8f9c5604001cde6e7ff9578bdd384f9282
ANTHROPIC_API_KEY=

# Qdrant (Vector DB for semantic memory)
# Default localhost:6333 for dev docker-compose. Leave empty to disable semantic search.
QDRANT_URL=http://localhost:6333

# ─── Browser stack (docker-compose.browser.yml) ───────────────────────────
# Optional services — only spin up what you need:
#   docker compose -f docker-compose.browser.yml up -d chrome
#   docker compose -f docker-compose.browser.yml up -d camofox
# ── Chromium (chrome service) ─────────────────
# Host ports — the Studio app connects via ws://localhost:${CHROME_CDP_PORT}.
CHROME_CDP_PORT=9222
CHROME_NOVNC_PORT=6080
# ── CamoFox (camofox service) ─────────────────
# Image is built from packages/camofox/docker (clones jo-inc/camofox-browser at
# build time). Pin the upstream ref — use a commit SHA or tag for reproducible
# rebuilds; `master` tracks the latest upstream.
CAMOFOX_REF=master
# Host port. Studio app connects via http://localhost:${CAMOFOX_PORT}.
CAMOFOX_PORT=9377
# Bearer token for Authorization header. REQUIRED to enable cookie import.
# Generate with `openssl rand -hex 32`. Leave blank to run without auth in dev.
CAMOFOX_API_KEY=
# Required to stop the CamoFox server via POST /stop.
CAMOFOX_ADMIN_KEY=
# Session & tab limits.
CAMOFOX_MAX_SESSIONS=20
CAMOFOX_MAX_TABS_PER_SESSION=10
CAMOFOX_SESSION_TIMEOUT_MS=1800000   # 30 min
CAMOFOX_IDLE_TIMEOUT_MS=300000       # 5 min
# Optional upstream proxy. Leave blank to disable.
CAMOFOX_PROXY_HOST=
CAMOFOX_PROXY_PORT=
CAMOFOX_PROXY_USERNAME=
CAMOFOX_PROXY_PASSWORD=